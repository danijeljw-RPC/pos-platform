# Copy to .env (repo root) and adjust for local development. Never commit a real .env file.
# Used by compose.yaml — the full local dev stack (db, keycloak, migrations, api, worker, web).
# See deploy/.env.example for the older, infra-only (db+keycloak) deploy/docker-compose.yml.

# PostgreSQL
POSTGRES_DB=daxapos
POSTGRES_USER=daxapos
POSTGRES_PASSWORD=daxapos_dev_password

# Keycloak — cloud/admin/back-office identity only (ADR-0013). Not required for the API to start
# or for GET /health to report healthy.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password

# Dev/local-only bootstrap admin (PLAN-0003 Milestone C, BootstrapAdminSeeder). If EITHER is
# unset, bootstrap seeding is skipped (the app still starts normally) — there is no fallback/
# guessable credential in source. Do not use these values in any production deployment.
DAXA_BOOTSTRAP_ADMIN_EMAIL=admin@daxapos.local
DAXA_BOOTSTRAP_ADMIN_PASSWORD=Local-Dev-Only-Passw0rd!
