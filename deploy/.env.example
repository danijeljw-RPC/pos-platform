# Copy to deploy/.env and adjust for local development. Never commit a real .env file.
#
# This covers only the PLAN-0002 platform skeleton (db + keycloak containers). Further
# variables (JWT signing, payment/sync credentials, etc. — see docs/deployment/docker-deployment.md)
# are added incrementally as those features are built (PLAN-0003 onward).

# PostgreSQL (deploy/docker-compose.yml `db` service)
POSTGRES_DB=daxapos
POSTGRES_USER=daxapos
POSTGRES_PASSWORD=daxapos_dev_password

# Keycloak (deploy/docker-compose.yml `keycloak` service) — cloud/admin/back-office identity only,
# per ADR-0013. Not required for the API to start or for GET /health to report healthy.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password

# Dev/local-only bootstrap admin (PLAN-0003 Milestone C, BootstrapAdminSeeder). Read by the API at
# startup. If EITHER is unset, bootstrap seeding is skipped (the app still starts normally) — there
# is no fallback/guessable credential in source. If a user with this email already exists, seeding
# is skipped without touching (and never resets) that user's password. Do not set these to a real
# admin's credentials, and do not use these values in any production deployment.
DAXA_BOOTSTRAP_ADMIN_EMAIL=admin@daxapos.local
DAXA_BOOTSTRAP_ADMIN_PASSWORD=Local-Dev-Only-Passw0rd!
