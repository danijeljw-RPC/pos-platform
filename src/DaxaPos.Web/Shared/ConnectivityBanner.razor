@using DaxaPos.Web.State
@using Microsoft.Extensions.DependencyInjection
@inject IServiceProvider ServiceProvider
@implements IDisposable

@*
    PLAN-0007 Milestone A. Resolves IConnectivityTracker via IServiceProvider.GetService (nullable),
    not @inject (which would use GetRequiredService and throw). This component is added to
    already-heavily-tested pages (Sales/Pay/Display/Kds); a page/test that doesn't register a
    tracker must keep working exactly as before, not start throwing because of an unrelated,
    additive change.
*@

@if (_connectivity is { Status: not ConnectivityStatus.Online } tracker)
{
    <div class="alert @(tracker.Status == ConnectivityStatus.Offline ? "alert-danger" : "alert-warning") py-2 px-3 mb-3" role="status">
        @(tracker.Status == ConnectivityStatus.Offline ? "Offline — trying to reconnect…" : "Reconnecting…")
    </div>
}

@code {
    private IConnectivityTracker? _connectivity;

    protected override void OnInitialized()
    {
        _connectivity = ServiceProvider.GetService<IConnectivityTracker>();

        if (_connectivity is not null)
        {
            _connectivity.Changed += HandleChanged;
        }
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        if (_connectivity is not null)
        {
            _connectivity.Changed -= HandleChanged;
        }
    }
}
