@page "/sales/pay/{OrderId:guid}"
@inject DaxaApiClient ApiClient
@inject IDeviceContextStore DeviceContextStore
@inject IDraftOrderStore DraftOrderStore
@inject NavigationManager Navigation

<PageTitle>Payment</PageTitle>

<ConnectivityBanner />

<h1>Payment</h1>

@if (_loadError is not null)
{
    <p class="text-danger" role="alert">@_loadError</p>
    <button type="button" id="retry-load" class="btn btn-outline-primary" @onclick="LoadAsync">Retry</button>
    <a href="/sales">Back to sales</a>
}
else if (_receipt is { } receipt)
{
    <h2 class="h5">Receipt</h2>

    <table class="table">
        <thead>
            <tr>
                <th>Item</th>
                <th class="text-end">Qty</th>
                <th class="text-end">Amount</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var line in receipt.Lines)
            {
                <tr>
                    <td>@line.ProductName @(line.TaxMarkerCode is { } marker ? $"({marker})" : "")</td>
                    <td class="text-end">@line.Quantity</td>
                    <td class="text-end">@FormatPrice(line.LineTotalAmount)</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between">
        <span>@receipt.TotalLabel</span>
        <span>@FormatPrice(receipt.GrandTotalAmount)</span>
    </div>
    <div class="d-flex justify-content-between">
        <span>@receipt.TaxInclusiveSummaryLabel</span>
        <span>@FormatPrice(receipt.TotalTaxAmount)</span>
    </div>

    @if (receipt.MarkerLegend.Count > 0)
    {
        <p class="text-muted small">@string.Join(", ", receipt.MarkerLegend)</p>
    }

    @if (receipt.Payments.Count > 0)
    {
        <h3 class="h6 mt-3">Payments</h3>
        <ul class="list-unstyled">
            @foreach (var payment in receipt.Payments)
            {
                <li>@payment.Method &mdash; @FormatPrice(payment.AmountApproved)</li>
            }
        </ul>
    }

    @if (receipt.Refunds.Count > 0)
    {
        <h3 class="h6 mt-3">Refunds</h3>
        <ul class="list-unstyled">
            @foreach (var refund in receipt.Refunds)
            {
                <li>@FormatPrice(refund.Amount) &mdash; @refund.ReasonCode</li>
            }
        </ul>
    }

    @if (_reprintMessage is not null)
    {
        <p role="status">@_reprintMessage</p>
    }

    <div class="d-flex gap-2 mt-3">
        <button type="button" id="reprint" class="btn btn-outline-secondary" disabled="@_isBusy" @onclick="ReprintAsync">Reprint receipt</button>
        <a href="/sales" class="btn btn-primary">New sale</a>
    </div>
}
else if (_order is { Status: OrderStatusResult.Completed })
{
    @if (_receiptError is not null)
    {
        <p class="text-danger" role="alert">@_receiptError</p>
        <button type="button" id="retry-receipt" class="btn btn-outline-primary" disabled="@_isBusy" @onclick="RetryReceiptAsync">Retry</button>
    }
    else
    {
        <p>Loading receipt&hellip;</p>
    }
}
else if (_order is null)
{
    <p>Loading order&hellip;</p>
}
else
{
    @if (_actionError is not null)
    {
        <p class="text-danger" role="alert">@_actionError</p>
        @if (_pendingPayment is not null)
        {
            <div class="d-flex gap-2 mb-3">
                <button type="button" id="retry-payment" class="btn btn-outline-primary btn-sm" disabled="@_isBusy" @onclick="RetryPendingPaymentAsync">Retry</button>
                <button type="button" id="check-payment-status" class="btn btn-outline-secondary btn-sm" disabled="@_isBusy" @onclick="CheckPaymentStatusAsync">Check status</button>
            </div>
        }
    }

    <div class="d-flex justify-content-between fw-semibold mb-3">
        <span>Balance due</span>
        <span>@FormatPrice(AmountDue)</span>
    </div>

    @if (_payments.Count > 0)
    {
        <h2 class="h6">Payments so far</h2>
        <ul class="list-unstyled">
            @foreach (var payment in _payments)
            {
                <li>@payment.Method &mdash; @FormatPrice(payment.AmountApproved ?? 0m)</li>
            }
        </ul>
    }

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <div class="border rounded p-3">
                <h2 class="h6">Cash</h2>
                <input id="cash-amount" type="number" step="0.01" class="form-control mb-2" value="@_cashAmount.ToString("0.00")" @onchange="e => _cashAmount = ParseAmount(e.Value)" />
                <button type="button" id="record-cash" class="btn btn-primary" disabled="@(_isBusy || _pendingPayment is not null)" @onclick="() => RecordPaymentAsync(PaymentMethodResult.Cash, _cashAmount)">Record cash payment</button>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="border rounded p-3">
                <h2 class="h6">Manual EFTPOS</h2>
                <input id="eftpos-amount" type="number" step="0.01" class="form-control mb-2" value="@_eftposAmount.ToString("0.00")" @onchange="e => _eftposAmount = ParseAmount(e.Value)" />
                <button type="button" id="record-eftpos" class="btn btn-primary" disabled="@(_isBusy || _pendingPayment is not null)" @onclick="() => RecordPaymentAsync(PaymentMethodResult.ManualEftpos, _eftposAmount)">Record manual EFTPOS payment</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid OrderId { get; set; }

    private OrderResult? _order;
    private IReadOnlyList<PaymentResult> _payments = [];
    private ReceiptResult? _receipt;
    private string? _loadError;
    private string? _actionError;
    private string? _receiptError;
    private string? _reprintMessage;
    private bool _isBusy;
    private decimal _cashAmount;
    private decimal _eftposAmount;

    /// <summary>
    /// PLAN-0007 Milestone C: a payment attempt that returned <see cref="ApiResultKind.NetworkFailure"/>
    /// — the request may or may not have reached the server, so it is neither confirmed nor known to
    /// have failed. Holds the exact <see cref="RecordPaymentRequest.IdempotencyKey"/> used, so an
    /// explicit staff Retry reuses it verbatim (never a new key for the same uncertain attempt) and a
    /// genuinely new payment only gets a fresh key once this is cleared.
    /// </summary>
    private (PaymentMethodResult Method, decimal Amount, Guid IdempotencyKey)? _pendingPayment;

    private decimal AmountPaid => _payments.Where(p => p.Status == PaymentStatusResult.Recorded).Sum(p => p.AmountApproved ?? 0m);

    private decimal AmountDue => _order is null ? 0m : _order.GrandTotalAmount - AmountPaid;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    /// <summary>
    /// PLAN-0007 Milestone A: also called from the "Retry" button shown alongside <see cref="_loadError"/>.
    /// </summary>
    private async Task LoadAsync()
    {
        _loadError = null;

        var orderResult = await ApiClient.GetOrderAsync(OrderId);
        if (orderResult.Kind != ApiResultKind.Success || orderResult.Value is null)
        {
            _loadError = ApiErrorMessages.ForLoadFailure(orderResult.Kind, "This order could not be found.");
            return;
        }

        _order = orderResult.Value;

        if (_order.Status == OrderStatusResult.Completed)
        {
            await EnterReceiptStateAsync();
            return;
        }

        if (_order.Status is not (OrderStatusResult.Open or OrderStatusResult.Held))
        {
            _loadError = "This order is no longer payable.";
            return;
        }

        await LoadPaymentsAsync();
        _cashAmount = AmountDue;
        _eftposAmount = AmountDue;
    }

    private async Task LoadPaymentsAsync()
    {
        var paymentsResult = await ApiClient.GetPaymentsAsync(OrderId);
        _payments = paymentsResult.Kind == ApiResultKind.Success && paymentsResult.Value is not null
            ? paymentsResult.Value
            : [];
    }

    private async Task RecordPaymentAsync(PaymentMethodResult method, decimal amount)
    {
        if (_order is null || amount <= 0 || _pendingPayment is not null)
        {
            return;
        }

        // A genuinely new attempt always gets a fresh idempotency key; Retry (below) reuses the
        // stored one instead. Only reachable once any prior uncertain attempt has been resolved
        // (Retry succeeded, Check status resolved it, or a rejection cleared it).
        await SubmitPaymentAsync(method, amount, Guid.NewGuid());
    }

    /// <summary>
    /// PLAN-0007 Milestone C: reattempts a payment that returned <see cref="ApiResultKind.NetworkFailure"/>,
    /// reusing <see cref="_pendingPayment"/>'s stored idempotency key so a request that actually
    /// reached the server the first time resolves to the same <c>Payment</c> row
    /// (<c>PaymentEndpoints</c>' existing idempotency check) instead of creating a duplicate.
    /// </summary>
    private async Task RetryPendingPaymentAsync()
    {
        if (_pendingPayment is { } pending)
        {
            await SubmitPaymentAsync(pending.Method, pending.Amount, pending.IdempotencyKey);
        }
    }

    private async Task SubmitPaymentAsync(PaymentMethodResult method, decimal amount, Guid idempotencyKey)
    {
        if (_order is null)
        {
            return;
        }

        _isBusy = true;
        _actionError = null;

        // PLAN-0007 Milestone D: revalidate immediately before the POST, not only after a rejection
        // (Milestone C) — narrows (does not eliminate — no server-side lock) the two-tabs-same-order
        // double-payment race by catching a since-completed/voided order proactively, avoiding a
        // doomed submit attempt. RefreshOrderAndPaymentsAsync leaves `_order` unchanged if the read
        // itself fails, so a network blip on this check falls through to the real attempt below
        // rather than blocking a write on an unrelated read failure.
        await RefreshOrderAndPaymentsAsync();
        if (_order is not { Status: OrderStatusResult.Open or OrderStatusResult.Held })
        {
            _pendingPayment = null;
            _actionError = ApiErrorMessages.OrderChangedElsewhere;
            await ApplyCompletionStateAsync();
            _isBusy = false;
            return;
        }

        var result = await ApiClient.RecordPaymentAsync(_order.Id, new RecordPaymentRequest(method, amount, idempotencyKey));
        if (result.Kind != ApiResultKind.Success || result.Value is null)
        {
            if (result.Kind == ApiResultKind.NetworkFailure)
            {
                // Uncertain, not failed: the request may have already reached the server. Preserve
                // it as a pending attempt rather than treating it as a rejection.
                _pendingPayment = (method, amount, idempotencyKey);
                _actionError = ApiErrorMessages.PaymentNotConfirmed;
                _isBusy = false;
                return;
            }

            // A real rejection (401/403/validation/conflict) is never retryable through this path.
            _pendingPayment = null;
            _actionError = result.Kind switch
            {
                ApiResultKind.Unauthorized => ApiErrorMessages.SessionExpired,
                ApiResultKind.Forbidden => ApiErrorMessages.Forbidden,
                _ => "This payment could not be recorded. It may exceed the amount owing.",
            };

            if (result.Kind == ApiResultKind.Failed)
            {
                // ADR-0007: revalidate against the server rather than trusting stale local state — a
                // rejection may mean the order changed underneath the staff member (completed/voided
                // elsewhere), not just that this specific amount was wrong.
                await RefreshOrderAndPaymentsAsync();
                await ApplyCompletionStateAsync();
            }

            _isBusy = false;
            return;
        }

        _pendingPayment = null;
        await RefreshOrderAndPaymentsAsync();
        await ApplyCompletionStateAsync();
        _isBusy = false;
    }

    /// <summary>
    /// PLAN-0007 Milestone C: staff-initiated recheck for an uncertain payment. Only reads server
    /// state (never resubmits <see cref="RecordPaymentAsync"/>), so it is always safe to press.
    /// Resolves <see cref="_pendingPayment"/> once a payment recorded under its idempotency key is
    /// found — the original request reached the server even though the response was lost — otherwise
    /// leaves it pending for another Retry or Check status.
    /// </summary>
    private async Task CheckPaymentStatusAsync()
    {
        if (_order is null)
        {
            return;
        }

        _isBusy = true;

        await RefreshOrderAndPaymentsAsync();

        if (_pendingPayment is { } pending && _payments.Any(p => p.IdempotencyKey == pending.IdempotencyKey))
        {
            _pendingPayment = null;
            _actionError = null;
        }

        await ApplyCompletionStateAsync();
        _isBusy = false;
    }

    private async Task RefreshOrderAndPaymentsAsync()
    {
        if (_order is null)
        {
            return;
        }

        var refreshed = await ApiClient.GetOrderAsync(_order.Id);
        if (refreshed.Kind == ApiResultKind.Success && refreshed.Value is not null)
        {
            _order = refreshed.Value;
        }

        await LoadPaymentsAsync();
    }

    private async Task ApplyCompletionStateAsync()
    {
        if (_order is null)
        {
            return;
        }

        if (_order.Status == OrderStatusResult.Completed)
        {
            await EnterReceiptStateAsync();
        }
        else
        {
            _cashAmount = AmountDue;
            _eftposAmount = AmountDue;
        }
    }

    /// <summary>
    /// PLAN-0007 Milestone C: previously swallowed a receipt-fetch failure silently, leaving
    /// <see cref="_receipt"/> null with no error set — for a <see cref="OrderStatusResult.Completed"/>
    /// order this fell through to the normal payment-entry UI, inviting a second payment attempt
    /// against an order that was already fully paid. Now sets <see cref="_receiptError"/> so the
    /// markup shows a distinct recoverable state instead.
    /// </summary>
    private async Task EnterReceiptStateAsync()
    {
        var receiptResult = await ApiClient.GetReceiptAsync(OrderId);
        if (receiptResult.Kind == ApiResultKind.Success && receiptResult.Value is not null)
        {
            _receipt = receiptResult.Value;
            _receiptError = null;
        }
        else
        {
            _receiptError = receiptResult.Kind switch
            {
                ApiResultKind.Unauthorized => ApiErrorMessages.SessionExpired,
                ApiResultKind.Forbidden => ApiErrorMessages.Forbidden,
                _ => ApiErrorMessages.ReceiptUnavailable,
            };
        }

        if (DeviceContextStore.Current is { } device)
        {
            await DraftOrderStore.ClearAsync(device.DeviceId);
        }
    }

    private async Task RetryReceiptAsync() => await EnterReceiptStateAsync();

    private async Task ReprintAsync()
    {
        _isBusy = true;

        var result = await ApiClient.ReprintReceiptAsync(OrderId);
        if (result.Kind == ApiResultKind.Success && result.Value is not null)
        {
            _receipt = result.Value;
            _reprintMessage = "Receipt reprinted.";
        }
        else
        {
            _reprintMessage = "Could not reprint the receipt.";
        }

        _isBusy = false;
    }

    private static decimal ParseAmount(object? value) =>
        decimal.TryParse(value?.ToString(), out var amount) ? amount : 0m;

    // AU/NZ launch markets both use "$"; pin the culture explicitly rather than relying on the
    // host's ambient CurrentCulture, which is invariant (renders "¤" not "$") on Linux hosts with
    // no locale configured.
    private static string FormatPrice(decimal amount) => amount.ToString("C", CultureInfo.GetCultureInfo("en-AU"));
}
