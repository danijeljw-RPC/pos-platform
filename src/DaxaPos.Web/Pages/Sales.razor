@page "/sales"
@inject DaxaApiClient ApiClient
@inject IDeviceContextStore DeviceContextStore
@inject IAuthSessionStore SessionStore
@inject IDraftOrderStore DraftOrderStore
@inject NavigationManager Navigation

<PageTitle>Sales</PageTitle>

<ConnectivityBanner />

<h1>Sales</h1>

@if (DeviceContextStore.Current is not { } device)
{
    <p>No device is registered on this browser yet. <a href="device-setup">Set up device</a>.</p>
}
else if (SessionStore.Current?.TerminalId is null)
{
    <p class="text-danger" role="alert">
        This device isn't linked to a POS terminal yet. Ask an admin to assign it to a terminal in
        Back Office &rarr; Terminals, then log in again.
    </p>
}
else if (_loadError is not null)
{
    <p class="text-danger" role="alert">@_loadError</p>
    <button type="button" id="retry-load" class="btn btn-outline-primary" @onclick="LoadAsync">Retry</button>
}
else if (_menu is null)
{
    <p>Loading menu&hellip;</p>
}
else
{
    @if (_actionError is not null)
    {
        <p class="text-danger" role="alert">@_actionError</p>
        @if (_pendingRetry is not null)
        {
            <button type="button" id="retry-add-line" class="btn btn-outline-primary btn-sm mb-2" disabled="@_isBusy" @onclick="RetryPendingAddLineAsync">Retry</button>
        }
    }

    <div class="row">
        <div class="col-12 col-lg-8">
            @if (_menu.Sections.Count == 0)
            {
                <p>No menu items are available for sale at this location right now.</p>
            }
            else
            {
                @foreach (var section in _menu.Sections.OrderBy(s => s.DisplayOrder))
                {
                    <h2 class="h5 mt-3">@section.SectionName</h2>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @foreach (var item in section.Items.OrderBy(i => i.DisplayOrder))
                        {
                            <button type="button"
                                    class="btn btn-outline-primary text-start"
                                    style="min-width: 8rem; max-width: 12rem;"
                                    disabled="@_isBusy"
                                    @onclick="() => TileTapped(item)">
                                <div class="fw-semibold text-wrap">@item.ProductName</div>
                                <div>@FormatPrice(item.Price)</div>
                            </button>
                        }
                    </div>
                }
            }
        </div>

        <div class="col-12 col-lg-4">
            <div class="border rounded p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h5 mb-0">Order</h2>
                    @if (_order is { Lines.Count: > 0 })
                    {
                        <button type="button" class="btn btn-sm btn-primary" disabled="@_isBusy" @onclick="GoToPay">Pay</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_isBusy" @onclick="ClearOrder">Clear order</button>
                    }
                </div>

                @{
                    var groups = BuildGroups();
                }

                @if (groups.Count == 0)
                {
                    <p class="text-muted">No items selected yet. Tap a menu item to add it.</p>
                }
                else
                {
                    @foreach (var group in groups)
                    {
                        <div class="border-bottom pb-2 mb-2">
                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold">@group.ProductName</span>
                                <span>@FormatPrice(group.TotalAmount)</span>
                            </div>
                            @if (group.ModifierNames.Count > 0)
                            {
                                <div class="text-muted small">@string.Join(", ", group.ModifierNames)</div>
                            }
                            <div class="d-flex align-items-center gap-2 mt-1">
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_isBusy" @onclick="() => Decrement(group)">-</button>
                                <span>@group.Quantity</span>
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_isBusy" @onclick="() => Increment(group)">+</button>
                                <button type="button" class="btn btn-sm btn-link text-danger ms-auto" disabled="@_isBusy" @onclick="() => Remove(group)">Remove</button>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-2">
                        <span>Subtotal</span>
                        <span>@FormatPrice(_order!.SubtotalAmount)</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Tax</span>
                        <span>@FormatPrice(_order!.TotalTaxAmount)</span>
                    </div>
                    <div class="d-flex justify-content-between fw-semibold">
                        <span>Total</span>
                        <span>@FormatPrice(_order!.GrandTotalAmount)</span>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (_selectingItem is { } selecting)
    {
        <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@selecting.ProductName</h5>
                    </div>
                    <div class="modal-body">
                        @foreach (var group in selecting.ModifierGroups.OrderBy(g => g.DisplayOrder))
                        {
                            var selected = _modalSelections.GetValueOrDefault(group.Id, []);
                            <fieldset class="mb-3">
                                <legend class="h6">
                                    @group.Name
                                    @if (group.IsRequired)
                                    {
                                        <span class="text-danger">*</span>
                                    }
                                    <span class="text-muted small">(choose @DescribeSelectionRange(group))</span>
                                </legend>
                                @foreach (var modifier in group.Modifiers)
                                {
                                    var isChecked = selected.Contains(modifier.Id);
                                    var atMax = selected.Count >= group.SelectionMax && !isChecked;
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="@($"mod-{modifier.Id}")"
                                               checked="@isChecked" disabled="@atMax"
                                               @onchange="e => ToggleModifier(group.Id, modifier.Id, e.Value is true)" />
                                        <label class="form-check-label" for="@($"mod-{modifier.Id}")">
                                            @modifier.Name
                                            @if (modifier.PriceDelta != 0)
                                            {
                                                <text> (@FormatPrice(modifier.PriceDelta))</text>
                                            }
                                        </label>
                                    </div>
                                }
                            </fieldset>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CancelModal">Cancel</button>
                        <button type="button" class="btn btn-primary" disabled="@(!CanConfirmModal(selecting) || _isBusy)" @onclick="() => ConfirmModal(selecting)">Add</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private ResolvedMenuResult? _menu;
    private string? _loadError;
    private string? _actionError;
    private OrderResult? _order;
    private bool _isBusy;

    /// <summary>
    /// PLAN-0007 Milestone B: the most recent add-line attempt that failed with
    /// <see cref="ApiResultKind.NetworkFailure"/>, offered back as a single staff-initiated Retry —
    /// never auto-replayed, never persisted, and overwritten (not queued) by the next attempt.
    /// </summary>
    private (Guid ProductId, IReadOnlyList<Guid> ModifierIds)? _pendingRetry;

    private ResolvedMenuItemResult? _selectingItem;
    private readonly Dictionary<Guid, List<Guid>> _modalSelections = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    /// <summary>
    /// PLAN-0007 Milestone A: also called from the "Retry" button shown alongside <see cref="_loadError"/>,
    /// so an initial load that fails (most commonly a network failure) can recover without a full
    /// page reload — the read path is the only thing retried; nothing here writes offline.
    /// </summary>
    private async Task LoadAsync()
    {
        if (DeviceContextStore.Current is not { } device || SessionStore.Current?.TerminalId is null)
        {
            return;
        }

        _loadError = null;

        var menuResult = await ApiClient.GetResolvedMenuAsync(device.LocationId);
        if (menuResult.Kind != ApiResultKind.Success || menuResult.Value is null)
        {
            _loadError = ApiErrorMessages.ForLoadFailure(menuResult.Kind, "Could not load the menu for this location.");
            return;
        }

        _menu = menuResult.Value;

        // Milestone C.1: restore the draft from the server, never from a local cache — a stored
        // OrderId that's gone (404) or already closed (Completed/Voided/Cancelled) is cleared so
        // the screen starts empty rather than showing stale/wrong state.
        var storedOrderId = await DraftOrderStore.GetOrderIdAsync(device.DeviceId);
        if (storedOrderId is not { } orderId)
        {
            return;
        }

        var orderResult = await ApiClient.GetOrderAsync(orderId);
        if (orderResult.Kind == ApiResultKind.Success
            && orderResult.Value is { Status: OrderStatusResult.Open or OrderStatusResult.Held } restored)
        {
            _order = restored;
        }
        else
        {
            await DraftOrderStore.ClearAsync(device.DeviceId);
        }
    }

    private void TileTapped(ResolvedMenuItemResult item)
    {
        if (item.ModifierGroups.Count == 0)
        {
            _ = AddLineAsync(item.ProductId, []);
            return;
        }

        _selectingItem = item;
        _modalSelections.Clear();
    }

    private void ToggleModifier(Guid groupId, Guid modifierId, bool isChecked)
    {
        var selected = _modalSelections.TryGetValue(groupId, out var existing) ? existing : _modalSelections[groupId] = [];

        if (isChecked)
        {
            if (!selected.Contains(modifierId))
            {
                selected.Add(modifierId);
            }
        }
        else
        {
            selected.Remove(modifierId);
        }
    }

    private bool CanConfirmModal(ResolvedMenuItemResult item) =>
        item.ModifierGroups.All(group =>
        {
            var count = _modalSelections.GetValueOrDefault(group.Id, []).Count;
            return count >= group.SelectionMin && count <= group.SelectionMax;
        });

    private static string DescribeSelectionRange(ResolvedModifierGroupResult group) =>
        group.SelectionMin == group.SelectionMax
            ? group.SelectionMin.ToString()
            : $"{group.SelectionMin}-{group.SelectionMax}";

    private async Task ConfirmModal(ResolvedMenuItemResult item)
    {
        var modifierIds = _modalSelections.Values.SelectMany(ids => ids).ToList();
        _selectingItem = null;
        await AddLineAsync(item.ProductId, modifierIds);
    }

    private void CancelModal() => _selectingItem = null;

    private async Task AddLineAsync(Guid productId, IReadOnlyList<Guid> modifierIds)
    {
        if (DeviceContextStore.Current is not { } device || SessionStore.Current?.TerminalId is not { } terminalId)
        {
            return;
        }

        _isBusy = true;
        _actionError = null;
        _pendingRetry = null;

        if (_order is null)
        {
            var openResult = await ApiClient.OpenOrderAsync(new CreateOrderRequest(terminalId));
            if (openResult.Kind != ApiResultKind.Success || openResult.Value is null)
            {
                SetAddLineFailure(openResult.Kind, productId, modifierIds, "Could not open an order for this terminal.");
                _isBusy = false;
                return;
            }

            _order = openResult.Value;
            await DraftOrderStore.SaveOrderIdAsync(device.DeviceId, _order.Id);
        }

        var addResult = await ApiClient.AddOrderLineAsync(
            _order.Id, new AddOrderLineRequest(productId, 1, modifierIds.Count > 0 ? modifierIds : null, null));

        if (addResult.Kind != ApiResultKind.Success || addResult.Value is null)
        {
            SetAddLineFailure(addResult.Kind, productId, modifierIds, "Could not add that item to the order.");
            _isBusy = false;
            return;
        }

        _order = addResult.Value;
        _isBusy = false;
    }

    /// <summary>
    /// PLAN-0007 Milestone B: a <see cref="ApiResultKind.NetworkFailure"/> here means the client
    /// never received a response — the request may or may not have reached the server, since
    /// neither <c>OpenOrderAsync</c> nor <c>AddOrderLineAsync</c> carries an idempotency key (unlike
    /// <c>RecordPaymentAsync</c>). Rather than auto-replaying (which could duplicate an order or a
    /// line), the attempt is preserved for an explicit staff-initiated Retry. A genuine rejection
    /// (401/403/404/Failed) is not retryable — retrying would just repeat the same rejection — so it
    /// keeps the existing generic message and no pending retry is offered.
    /// </summary>
    private void SetAddLineFailure(ApiResultKind kind, Guid productId, IReadOnlyList<Guid> modifierIds, string genericMessage)
    {
        if (kind == ApiResultKind.NetworkFailure)
        {
            _actionError = ApiErrorMessages.AddLineNotConfirmed;
            _pendingRetry = (productId, modifierIds);
        }
        else
        {
            _actionError = ApiErrorMessages.ForLoadFailure(kind, genericMessage);
        }
    }

    private async Task RetryPendingAddLineAsync()
    {
        if (_pendingRetry is { } pending)
        {
            await AddLineAsync(pending.ProductId, pending.ModifierIds);
        }
    }

    private async Task Increment(CartGroup group) => await AddLineAsync(group.ProductId, group.ModifierIds);

    private async Task Decrement(CartGroup group)
    {
        if (_order is null || group.LineIds.Count == 0)
        {
            return;
        }

        _isBusy = true;
        _actionError = null;

        var result = await ApiClient.VoidOrderLineAsync(_order.Id, group.LineIds[^1], "Decremented by staff");
        if (result.Kind == ApiResultKind.Success && result.Value is not null)
        {
            _order = result.Value;
        }
        else
        {
            _actionError = ApiErrorMessages.ForLoadFailure(result.Kind, "Could not update that item's quantity.");
        }

        _isBusy = false;
    }

    private async Task Remove(CartGroup group)
    {
        if (_order is null)
        {
            return;
        }

        _isBusy = true;
        _actionError = null;

        foreach (var lineId in group.LineIds)
        {
            var result = await ApiClient.VoidOrderLineAsync(_order.Id, lineId, "Removed by staff");
            if (result.Kind == ApiResultKind.Success && result.Value is not null)
            {
                _order = result.Value;
            }
            else
            {
                _actionError = ApiErrorMessages.ForLoadFailure(result.Kind, "Could not remove that item.");
                break;
            }
        }

        _isBusy = false;
    }

    private void GoToPay()
    {
        if (_order is not null)
        {
            Navigation.NavigateTo($"/sales/pay/{_order.Id}");
        }
    }

    private async Task ClearOrder()
    {
        if (_order is null || DeviceContextStore.Current is not { } device)
        {
            return;
        }

        _isBusy = true;
        _actionError = null;

        var result = await ApiClient.VoidOrderAsync(_order.Id, "Cleared by staff");
        if (result.Kind == ApiResultKind.Success)
        {
            await DraftOrderStore.ClearAsync(device.DeviceId);
            _order = null;
        }
        else
        {
            _actionError = ApiErrorMessages.ForLoadFailure(result.Kind, "Could not clear the order.");
        }

        _isBusy = false;
    }

    private List<CartGroup> BuildGroups()
    {
        if (_order is null)
        {
            return [];
        }

        var groups = new List<CartGroup>();

        // Preserve the server's own line order (already CreatedAtUtc-ascending, see
        // BuildOrderResponseAsync) — LineIds[^1] below relies on it to mean "most recently added".
        foreach (var line in _order.Lines.Where(l => l.Status == OrderLineStatusResult.Active))
        {
            var modifierIds = line.Modifiers.Select(m => m.ModifierId).OrderBy(id => id).ToList();
            var existing = groups.FirstOrDefault(g => g.ProductId == line.ProductId && g.ModifierIds.SequenceEqual(modifierIds));

            if (existing is not null)
            {
                existing.Quantity += line.Quantity;
                existing.TotalAmount += line.LineTotalAmount;
                existing.LineIds.Add(line.Id);
                continue;
            }

            groups.Add(new CartGroup(
                line.ProductId,
                line.ProductNameSnapshot,
                modifierIds,
                line.Modifiers.Select(m => m.NameSnapshot).ToList())
            {
                Quantity = line.Quantity,
                TotalAmount = line.LineTotalAmount,
                LineIds = [line.Id],
            });
        }

        return groups;
    }

    // AU/NZ launch markets both use "$"; pin the culture explicitly rather than relying on the
    // host's ambient CurrentCulture, which is invariant (renders "¤" not "$") on Linux hosts with
    // no locale configured.
    private static string FormatPrice(decimal amount) => amount.ToString("C", CultureInfo.GetCultureInfo("en-AU"));

    private sealed class CartGroup(Guid productId, string productName, IReadOnlyList<Guid> modifierIds, IReadOnlyList<string> modifierNames)
    {
        public Guid ProductId { get; } = productId;

        public string ProductName { get; } = productName;

        public IReadOnlyList<Guid> ModifierIds { get; } = modifierIds;

        public IReadOnlyList<string> ModifierNames { get; } = modifierNames;

        public int Quantity { get; set; }

        public decimal TotalAmount { get; set; }

        public List<Guid> LineIds { get; set; } = [];
    }
}
